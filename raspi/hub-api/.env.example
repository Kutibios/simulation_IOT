# Kopyala: mkdir -p ~/.config/iot-hub && cp .env.example ~/.config/iot-hub/.env

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=
INFLUX_ORG=iot-hub
INFLUX_BUCKET=iot_telemetry
INFLUX_MEASUREMENT=telemetry

MQTT_BROKER=127.0.0.1
MQTT_PORT=1883

API_HOST=0.0.0.0
API_PORT=5000

# İsteğe bağlı: varsayılan ~/.config/iot-hub/.env
# IOT_HUB_ENV_FILE=/home/kutay/.config/iot-hub/.env
